{
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true,
        "**/.venv": true,
        "**/__pycache__": true
    },

    "[python]": {
        "editor.codeActionsOnSave": {
            "source.unusedImports": "never",
        }
    },
}
